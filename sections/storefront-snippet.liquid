{% comment %}
  P21 Auto-Sync Snippet

  SETUP:
  1. In Shopify Admin, go to Online Store > Pages > Add page
     - Title: "Preparing Your Order" (or similar)
     - Save the page
  2. In Online Store > Themes > Customize, navigate to that page
  3. Add a "Custom Liquid" section and paste this entire snippet into it
  4. On your cart page, change the checkout button URL to point to /pages/preparing-your-order
     (or whatever handle your page gets)

  This will sync P21 data to the customer profile, then redirect to checkout.
{% endcomment %}

{% if customer %}
<div id="p21-sync-loading" style="text-align:center;padding:60px 20px;font-family:inherit;">
  <h2>Preparing your order...</h2>
  <p style="color:#666;">One moment while we load your account details.</p>
</div>

<script>
(function() {
  var email = {{ customer.email | json }};
  var checkoutUrl = '/checkout';

  if (!email) {
    window.location.href = checkoutUrl;
    return;
  }

  fetch('https://antony-undamaging-thersa.ngrok-free.dev/sync/auto', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: email })
  })
  .then(function() { window.location.href = checkoutUrl; })
  .catch(function() { window.location.href = checkoutUrl; });

  // Safety timeout — redirect after 5 seconds no matter what
  setTimeout(function() { window.location.href = checkoutUrl; }, 5000);
})();
</script>
{% else %}
<script>
  window.location.href = '/account/login?return_url=' +
    encodeURIComponent('/pages/preparing-your-order');
</script>
{% endif %}
