{% comment %}
  Renders one block per linked collection from the product metafield
  `custom.related_option_collections` (type: List of collections).

  Each block:
    - Heading is the linked collection's title
    - Grid below shows products from that collection (slim image-only cards)
    - "View all" link to the collection page
{% endcomment %}

{%- if product.metafields.custom.related_option_collections.value != blank -%}
  {%- assign linked_collections = product.metafields.custom.related_option_collections.value -%}

  <div class="product__related-option-collections">
    {%- for linked_collection in linked_collections -%}
      {%- if linked_collection.products_count > 0 -%}
        <section class="related-option-collection">
          <div class="related-option-collection__header">
            <h2 class="h5 related-option-collection__heading">
              {{ linked_collection.title | escape }}
            </h2>
            <a
              class="h5 related-option-collection__view-all"
              href="{{ linked_collection.url }}"
              aria-label="View all products in {{ linked_collection.title | escape }}"
            >
              View all
            </a>
          </div>

          <div class="related-option-collection__grid">
            {%- for related_product in linked_collection.products limit: 12 -%}
              <a
                class="related-option-collection__item"
                href="{{ related_product.url }}"
                aria-label="{{ related_product.title | escape }}"
                title="{{ related_product.title | escape }}"
              >
                {%- if related_product.featured_media.preview_image -%}
                  {%- assign card_img = related_product.featured_media.preview_image -%}
                  <img
                    class="related-option-collection__image"
                    src="{{ card_img | image_url: width: 600 }}"
                    srcset="{{ card_img | image_url: width: 300 }} 300w, {{ card_img | image_url: width: 600 }} 600w, {{ card_img | image_url: width: 900 }} 900w"
                    sizes="(max-width: 600px) 45vw, (max-width: 860px) 33vw, 250px"
                    alt="{{ related_product.title | escape }}"
                    width="{{ card_img.width }}"
                    height="{{ card_img.height }}"
                    loading="lazy"
                  >
                {%- else -%}
                  {% render 'placeholder-image', use_setting: true, svg_fallback: 'product-1', class: 'related-option-collection__placeholder' %}
                {%- endif -%}
              </a>
            {%- endfor -%}
          </div>
        </section>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <style>
    .product__related-option-collections {
      margin-top: 1.5rem;
    }
    .product__related-option-collections .related-option-collection {
      margin-bottom: 2rem;
    }
    .product__related-option-collections .related-option-collection__header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.75rem;
    }
    .product__related-option-collections .related-option-collection__heading {
      margin: 0;
    }
    .product__related-option-collections .related-option-collection__view-all {
      text-decoration: underline;
      white-space: nowrap;
      margin: 0;
    }
    .product__related-option-collections .related-option-collection__grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
    .product__related-option-collections .related-option-collection__item {
      display: block;
      text-decoration: none;
      color: inherit;
      background: #fff;
      border: 1px solid #D6DBDD;
      transition: border-color 120ms ease;
    }
    .product__related-option-collections .related-option-collection__item:hover {
      border-color: #111;
    }
    .product__related-option-collections .related-option-collection__image {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      object-fit: contain;
    }
    .product__related-option-collections .related-option-collection__placeholder {
      display: block;
      width: 100%;
      height: auto;
    }
    @media (max-width: 860px) {
      .product__related-option-collections .related-option-collection__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 600px) {
      .product__related-option-collections .related-option-collection__item:nth-child(n+3) {
        display: none;
      }
    }

  </style>
{%- endif -%}