{%- liquid
    assign filter_block = nil
    assign sidebar_blocks = false
    assign menu_block_count = 0
    assign products_per_row = section.settings.products_per_row

    for block in section.blocks
        if block.type == 'filter'
            assign filter_block = block
            assign sidebar_blocks = true
        elsif block.type == 'menu'
            assign sidebar_blocks = true
            assign menu_block_count = menu_block_count | plus: 1
        endif
    endfor

    assign filter_type = 'tag'
    if filter_block and filter_block.settings.filter_option == 'faceted'
        assign filter_type = 'faceted'
    endif

    capture section_type
        if filter_type == 'faceted'
            echo 'static-collection-faceted-filters'
        else
            echo 'static-collection'
        endif
    endcapture

    assign current_tag_handles = ''

    for tag in current_tags
        assign current_tag = tag | handle
        assign current_tag_handles = current_tag_handles | append: current_tag
        unless forloop.last
            assign current_tag_handles = current_tag_handles | append: '|'
        endunless
    endfor

    assign current_tag_array = current_tag_handles | split: '|'

    assign show_sidebar = false
    assign show_filters = true
    assign show_filter_trigger = false

    assign is_all_collection = false
    if collection.url contains '/collections/shop'
        assign is_all_collection = true
    endif

    if filter_block == nil or filter_block.settings.filter_option == 'tag' and collection.all_tags.size == 0
        assign show_filters = false
    endif

    if filter_block == nil or filter_block.settings.filter_option == 'tag' and collection.all_tags.size == 0
        assign show_filters = false
    endif

    if sidebar_blocks
        if show_filters or menu_block_count > 0
            assign show_filter_trigger = true
        endif

        if is_all_collection
            assign show_sidebar = true
        endif
    endif

    assign paginate_by = section.settings.products_per_page_range

    capture collection_classes
        if show_sidebar
            echo 'layout--has-sidebar '
        else
            echo 'layout--no-sidebar '
        endif

        if section.settings.default_view == 'grid-view'
            echo 'productgrid-gridview '
        else
            echo 'productgrid-listview '
        endif

		if collection.products.size == 0
			echo 'collection--zero-items '
		else
			echo 'collection--has-items '
		endif
    endcapture

    assign hero_tag_filter = nil
    for filter in collection.filters
        if filter.param_name == 'filter.p.tag'
            assign hero_tag_filter = filter
            break
        endif
    endfor

    assign allowed_tags_raw = section.settings.allowed_filter_tags | default: '' | strip | downcase
    assign allowed_tags_norm = allowed_tags_raw | replace: ', ', ',' | replace: ' ,', ',' | split: ','
    assign hero_tag_allowlist_active = false
    if allowed_tags_raw != ''
        assign hero_tag_allowlist_active = true
    endif
-%}

<script
  type="application/json"
  data-section-type="{{ section_type | strip }}"
  data-section-id="{{ section.id }}"
    {%- assign primary_collection_filter = blank -%}

    {%- for f in collection.filters -%}
        {%- if f.param_name contains 'filter.p.m.custom.primary_collection' -%}
            {%- assign primary_collection_filter = f -%}
            {%- break -%}
        {%- endif -%}
    {%- endfor -%}

  data-section-data
>
{
  "show_filter_product_count": {{ filter_block.settings.show_filter_product_count | json }},
  "product_count": {{ collection.products_count | json }},
  "filter_type": {{ filter_type | json }},
  "filter_groups": {{ filter_block.settings.filter_groups | json }},
  "filter_style": {{ filter_block.settings.filter_style | json }},

  "primary_collection_filter": {
    "enabled":
      {%- if primary_collection_filter != blank -%}true{%- else -%}false{%- endif -%},
    "label":
      {%- if primary_collection_filter != blank -%}
        {{ primary_collection_filter.label | json }}
      {%- else -%}
        {{ 'Primary collection' | json }}
      {%- endif -%},
    "values": [
      {%- if primary_collection_filter != blank -%}
        {%- for v in primary_collection_filter.values -%}
          {
            "label": {{ v.label | json }},
            "value": {{ v.value | json }},
            "param_name": {{ v.param_name | json }},
            "active": {%- if v.active -%}true{%- else -%}false{%- endif -%},
            "count": {{ v.count | json }},
            "disabled": {%- if v.count == 0 and v.active == false -%}true{%- else -%}false{%- endif -%}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    ]
  },

  "no_matched_products_text": {{ 'general.accessibility.no_matched_products' | t: tag: '*tag*' | json }},
  "context": {
    "see_more": {{ 'general.general.see_more' | t | json }},
    "see_less": {{ 'general.general.see_less' | t | json }},
    "grid_list": {{ section.settings.default_view | json }},
    "collectionUrl": {{ collection.url | default: '/collections/shop' | json }},
    "current_tags": {{ current_tag_array | json }}
  },
  "enable_product_compare": {{ settings.enable_product_compare | json }}
}
</script>


{% style %}
    #shopify-section-{{ section.id }} .subcollections-list__content {
        grid-template-columns: repeat(7, minmax(auto, 1fr));
    }
    @media only screen and (max-width: 860px) {
        #shopify-section-{{ section.id }} .subcollections-list__content {
            grid-template-columns: repeat(5, minmax(auto, 1fr));
        }
    }
    @media only screen and (max-width: 480px) {
        #shopify-section-{{ section.id }} .subcollections-list__content {
            grid-template-columns: repeat(3, minmax(auto, 1fr));
        }
    }

    #shopify-section-{{ section.id }} .collection--hero-filters {
        margin-top: 1.25rem;
        text-align: center;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__label {
        font-size: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 0 0 0.5rem 0;
        opacity: 1;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
        align-items: center;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__chip {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.25rem 0.5rem;
        font-size: 1.3rem;
        line-height: 1.2;
        text-decoration: none;
        background: transparent;
        color: inherit;
        cursor: pointer;
        transition: color 120ms ease;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__chip-box {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
        width: 1.25rem;
        height: 1.25rem;
        border: 2px solid currentColor;
        border-radius: 3px;
        background: transparent;
        transition: background-color 120ms ease, border-color 120ms ease;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__chip-box::after {
        content: "";
        display: block;
        width: 0.4rem;
        height: 0.7rem;
        border-right: 2px solid #fff;
        border-bottom: 2px solid #fff;
        transform: rotate(45deg) translate(-1px, -1px);
        opacity: 0;
        transition: opacity 120ms ease;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__chip:hover .collection--hero-filters__chip-box {
        background: rgba(0, 0, 0, 0.06);
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__chip.is-active .collection--hero-filters__chip-box {
        background: #111;
        border-color: #111;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__chip.is-active .collection--hero-filters__chip-box::after {
        opacity: 1;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__chip-label {
        line-height: 1.2;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__clear-item {
        flex-basis: 100%;
        margin-top: 0.5rem;
    }
    #shopify-section-{{ section.id }} .collection--hero-filters__clear {
        font-size: 1.3rem;
        text-decoration: underline;
    }
{% endstyle %}

{% render 'breadcrumbs' %}

{% paginate collection.products by paginate_by %}
    <div class="container--grid">
        <div class="productgrid--outer {{ collection_classes | strip_newlines }}" data-productgrid-outer>

            {% comment %} Container [Masthead] {% endcomment %}
            <div class="productgrid--masthead wrap--container">
                <div class="wrap--max push--center">
                    {% comment %}Variant [Collection — All] {% endcomment %}
                    {% if collection.url == '/collections/shop' %}
                        <div class="container--header-ready-made">
                            <div class="block--content">
                                <h1 class="collection--title custom-all-collections-title">Shop our Available Standard Configurations</h1>
                                <div class="collection--description rte" data-collection-description>
                                    <p> We provide both standard and customizable configurations. Shop our selection of standard configurations here and contact us to inquire about our vast array of customizable products. Paquin is your one-stop shop for sensor-based instrumentation, process control equipment and accessories.</p>
                                </div>
                            </div>
                            <div class="block--barksdale">
                                <h3>Need Custom Parts? View our vast product portfolio</h3>
                                <p>We provide 100s of high quality parts with billions of configurations available to perfectly suit your exact needs. View our full portfolio of transmitters, switches, sensors, and meters for pressure, temperature, flow, level, opticals, lasers, gas detection, humidity, proximity, pumps, valves, oil and water detection, electrical connectivity, diaphragm seals and adaptors, and more at <a href="/pages/paquin-sensors">Paquin Sensors</a>.</p>
                            </div>
                            <div class="block--sensors">
                                <h3>Shop All Paquin Sensors Parts</h3>
                                <p>For a complete view of all that Paquin Sensors has to offer, <a href="/pages/paquin-sensors">click here</a>.</p>
                                <div class="block__cta">
                                    <a href="/pages/contact" class="button--base button--icon-before button--icon-arrow-forward">Contact Our Team</a>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        {% comment %} Variant [Base] {% endcomment %}
                        {% if collection.products.size > 0 %}
                            <div class="container--grid variant--base">
                                {% if collection.image %}
                                    <div class="container--image">
                                        <div class="wrap--image">
                                            {{ collection.image | img_url: 'master' | img_tag: collection.title }}
                                        </div>
                                    </div>
                                {% endif %}
                                <div class="container--content">
                                    <h1 class="collection--title">
                                        {%- render 'collection-title-formatted', collection: collection -%}
                                    </h1>
                                    {% if collection.description != blank %}
                                        <div class="collection--description rte" data-collection-description>
                                            {{ collection.description }}
                                            {% if collection.metafields.custom.collection_information %}
                                                <a href="#section--collection-information" class="link--icon-before link--icon-arrow-down">Learn more</a>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    {% if collection.metafields.custom.supporting_documents != blank %}
                                    {% assign docs = collection.metafields.custom.supporting_documents.value %}
                                    {% if docs != blank %}
                                        <div class="collection--supporting-docs" style="margin-top:1rem; text-align:center;">
                                        <h3 class="supporting-docs__heading">Collection Brochures</h3>

                                        <div class="supporting-docs__buttons"
                                            style="display:flex; gap:.5rem; flex-wrap:wrap; justify-content:center; align-items:center;">
                                            {% for doc in docs %}
                                            <a
                                                href="{{ doc.url }}"
                                                class="button--base button--outline button--icon-before"
                                                target="_blank" rel="noopener"
                                            >
                                                <span class="button__icon">
                                                {% render 'icon-library', id: 'icon-data-sheet' %}
                                                </span>
                                                <span class="button__text">
                                                {{ doc.alt | default: doc.filename }}
                                                </span>
                                            </a>
                                            {% endfor %}
                                        </div>
                                        </div>
                                    {% endif %}
                                    {% endif %}

                                    {%- comment -%} Hero tag filters (below description / docs) {%- endcomment -%}
                                    {%- if hero_tag_filter and hero_tag_filter.values.size > 0 -%}
                                        <div class="collection--hero-filters" data-hero-tag-filters>
                                            <p class="collection--hero-filters__label">Filter by tag</p>
                                            <ul class="collection--hero-filters__list">
                                                {%- for value in hero_tag_filter.values -%}
                                                    {%- liquid
                                                        assign show_this_tag = true
                                                        if hero_tag_allowlist_active
                                                            assign show_this_tag = false
                                                            assign value_norm = value.value | downcase | strip
                                                            assign label_norm = value.label | downcase | strip
                                                            if allowed_tags_norm contains value_norm
                                                                assign show_this_tag = true
                                                            elsif allowed_tags_norm contains label_norm
                                                                assign show_this_tag = true
                                                            endif
                                                        endif
                                                    -%}
                                                    {%- if show_this_tag and value.count > 0 or show_this_tag and value.active -%}
                                                        <li>
                                                            <a
                                                                href="{%- if value.active -%}{{ value.url_to_remove }}{%- else -%}{{ value.url_to_add }}{%- endif -%}"
                                                                class="collection--hero-filters__chip{%- if value.active %} is-active{%- endif %}"
                                                                rel="nofollow"
                                                                role="checkbox"
                                                                aria-checked="{%- if value.active -%}true{%- else -%}false{%- endif -%}"
                                                            >
                                                                <span class="collection--hero-filters__chip-box" aria-hidden="true"></span>
                                                                <span class="collection--hero-filters__chip-label">{{ value.label | escape }}</span>
                                                            </a>
                                                        </li>
                                                    {%- endif -%}
                                                {%- endfor -%}
                                                {%- if hero_tag_filter.active_values.size > 0 -%}
                                                    <li class="collection--hero-filters__clear-item">
                                                        <a
                                                            href="{{ hero_tag_filter.url_to_remove }}"
                                                            class="collection--hero-filters__clear"
                                                            rel="nofollow"
                                                        >
                                                            Clear filters
                                                        </a>
                                                    </li>
                                                {%- endif -%}
                                            </ul>
                                        </div>
                                    {%- endif -%}
                                </div>
                            </div>
                        {% else %}
                            {% comment %} Variant [Empty] {% endcomment %}
                            <div class="container--grid variant--empty">
                                {% if collection.image %}
                                    <div class="container--image">
                                        <div class="wrap--image">
                                            {{ collection.image | img_url: 'master' | img_tag: collection.title }}
                                        </div>
                                    </div>
                                {% endif %}
                                <div class="container--content">
                                    <h1 class="collection--title">
                                        {%- render 'collection-title-formatted', collection: collection -%}
                                    </h1>
                                    <p>We are excited to present our {{ collection.title }} product portfolio — we will post datasheets, press releases and new product announcements soon. Until then, we can support your {{ collection.title }} requirements - please <a href="/pages/contact/">get in touch</a> with our specialists who are ready to assist you.</p>
                                    <a class="button--base button--icon-before button--icon-arrow-forward" href="/pages/contact/">Contact our team</a>
                                    {% if collection.metafields.custom.supporting_documents != blank %}
                                    {% assign docs = collection.metafields.custom.supporting_documents.value %}
                                    {% if docs != blank %}
                                        <div class="collection--supporting-docs" style="margin-top:1rem;">
                                        <h3 class="supporting-docs__heading">Supporting documents</h3>
                                        <div class="supporting-docs__buttons" style="display:flex; gap:.5rem; flex-wrap:wrap;">
                                            {% for doc in docs %}
                                            <a
                                                href="{{ doc.url }}"
                                                class="button--outline button--icon-before button--icon-data-sheet"
                                                target="_blank" rel="noopener"
                                            >
                                                {{ doc.alt | default: doc.filename | default: 'Download' }}
                                            </a>
                                            {% endfor %}
                                        </div>
                                        </div>
                                    {% endif %}
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            {% comment %} Feed [Subcollection] {% endcomment %}
            {% if collection.metafields.custom.subcollections != blank %}
                <section class="section--subcollections wrap--container">
                    <div class="wrap--max push--center">
                        <div class="section__grid">
                            <div class="container--heading">
                                <h2 class="section__heading align--center">Product Subcategories</h2>
                            </div>
                            <div class="container--feed">
                                {% render 'feed-subcollection', data_subcollections: collection.metafields.custom.subcollections %}
                            </div>
                        </div>
                    </div>
                </section>
            {% endif %}

            {% if collection.products.size > 0 and collection.metafields.custom.show_products != false %}
                {% comment %} Container [Sidebar] {% endcomment %}
             {% if show_sidebar and is_all_collection %}
                    <div class="container--sidebar-feed wrap--container">
                        <div class="container--grid wrap--max push--center">
                            {%
                            render 'product-grid-sidebar',
                            menu_depth: section.settings.menu_depth_range,
                            context: collection,
                            filter_block: filter_block,
                            filter_type: filter_type,
                            filter_style: filter_block.settings.filter_style,
                            filter_limit: filter_block.settings.filter_limit,
                            show_filter_product_count: filter_block.settings.show_filter_product_count
                            %}

                {% endif %}
                {% comment %} Container [Product Feed] {% endcomment %}
                <div id="section--feed" class="productgrid--wrapper wrap--container">
                    <div class="wrap--max push--center">
                        {% if show_filter_trigger or section.settings.sort_by or section.settings.grid_list %}
                            {% capture utility_class %}
                                productgrid--utils
                                {% if show_filter_trigger or section.settings.sort_by or section.settings.grid_list %}
                                    productgrid--utils--visible-mobile
                                {% endif %}
                                {% unless section.settings.sort_by or section.settings.grid_list %}
                                    productgrid--utils--hidden-desktop
                                {% endunless %}
                            {% endcapture %}
                            <div class="productgrid--utils-sticky-intersection" data-utils-intersection-target></div>
                            <nav
                                class="
                                    {{ utility_class | strip_newlines }}
                                    productgrid--utils-container
                                    productgrid--utils-sticky
                                "
                                aria-label="{{ 'general.accessibility.nav_collection_utilities' | t }}"
                                data-sticky-utils
                            >
                                {% if show_filter_trigger %}
                                    {% liquid
                                        assign filter_count = 0

                                        if filter_block.settings.filter_option == 'faceted'
                                            for filter in collection.filters
                                            if filter.type == 'price_range'
                                                if filter.min_value.value != blank or filter.max_value.value != blank
                                                assign filter_count = filter_count | plus: 1
                                                endif
                                            elsif filter.type == 'list'
                                                assign filter_count = filter_count | plus: filter.active_values.size
                                            endif
                                            endfor
                                        else
                                            if current_tags.size > 0
                                            assign filter_count = current_tags.size
                                            endif
                                        endif
                                        %}
                                    <div class="productgrid--utils utils-filter">
                                        <button class="utils-filter-button" type="button" aria-label="{{ button_label }}" data-productgrid-trigger-filters>
                                            <span class="utils-filter-icon">
                                                {% render 'icon-library', id: 'icon-filters' %}
                                            </span>
                                            <span class="utils-filter-text">
                                                {{- button_label -}}
                                            </span>
                                        </button>
                                    </div>
                                {% endif %}

                                {%- if section.settings.sort_by -%}
                                    {%- render 'product-grid-sortby', type: 'select' -%}
                                {%- endif -%}

                                {% if section.settings.grid_list or settings.enable_product_compare %}
                                    <div class="productgrid--utils utils-view{% if section.settings.grid_list == false %} utils-hide{% endif %}">
                                        <div class="utils-view-container">
                                            {% if settings.enable_product_compare %}
                                                <div class="utils-compare-toggle">
                                                    <span class="utils-compare-toggle__label">
                                                        {{ 'product_compare.compare' | t }}
                                                    </span>

                                                    <div class="utils-compare-toggle__container">
                                                        <input class="utils-compare-toggle__checkbox visually-hidden" id="utils-compare-toggle__checkbox" aria-label="{{ 'product_compare.compare' | t }}" type="checkbox" data-compare-toggle>
                                                        <label class="utils-compare-toggle__checkbox-label" for="utils-compare-toggle__checkbox"></label>
                                                        {%
                                                            render 'icon-library',
                                                            id: 'icon-checkmark',
                                                            icon_class: 'utils-compare-toggle__checkbox-icon',
                                                        %}
                                                    </div>
                                                </div>
                                            {% endif %}

                                            {% if section.settings.grid_list %}
                                                <div class="utils-viewtoggle">
                                                    <span class="utils-viewtoggle-label">{{ 'product_grid.view_as.title' | t }}</span>
                                                    <button class="utils-viewtoggle-button {% if section.settings.default_view == 'grid-view' %}active{% endif %}" data-collection-view="grid-view" aria-label="grid view" >
                                                        {% render 'icon-library', id: 'icon-grid' %}
                                                    </button>
                                                    <button class="utils-viewtoggle-button {% if section.settings.default_view == 'list-view' %}active{% endif %}" data-collection-view="list-view" aria-label="list view" >
                                                        {% render 'icon-library', id: 'icon-list' %}
                                                    </button>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                {%- endif -%}
                            </nav>
                        {% endif %}
                        {% if collection.url contains '/collections/shop' %}
                          <div class="section__content">
                            {% if collection.products.size > 0 %}
                            <div class="section__heading">
                                <h2 class="section__heading">Browse Products</h2>
                            </div>

                            {% paginate collection.products by 24 %}
                                <div class="productgrid--items products-per-row-{{- products_per_row -}}" data-productgrid-items>
                                    {% for product in collection.products %}
                                        {% if product.price_min > 0 %}
                                        {% render 'product-grid-item',
                                            product: product,
                                            context: 'collection',
                                            index: forloop.index,
                                            products_per_row: products_per_row
                                        %}
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {{ paginate | default_pagination }}
                            {% endpaginate %}

                            {% endif %}
                          </div>
                        {% else %}
                            {% if collection.products.size > 0 %}
                                <div class="section__heading">
                                    <h2 class="section__heading">Browse Products</h2>
                                </div>

                                <div
                                    class="productgrid--items products-per-row-{{- products_per_row -}}"
                                    data-html="productgrid-items"
                                    data-productgrid-items
                                >
                                    {% for product in collection.products %}
                                    {%
                                        render 'product-grid-item',
                                        product: product,
                                        context: 'collection',
                                        index: forloop.index,
                                        products_per_row: products_per_row,
                                    %}
                                    {% endfor %}
                                </div>
                                {% endif %}

                            {% render 'pagination', paginate: paginate, grid_list: true %}
                        {% endif %}
                    </div>
                </div>
                {% if show_sidebar and is_all_collection %}
                        </div>
                    </div>
                {% endif %}
            {% endif %}
        </div>
    </div>
{% endpaginate %}

{% comment %} Container [Additional Details] {% endcomment %}
{% if collection.metafields.custom.collection_information.value != blank %}
    {% render 'collection-content-offset-details', collection: collection %}
{% endif %}

{%- if section.settings.sort_by -%}
    {%- render 'product-grid-sortby', type: 'modal', -%}
{%- endif -%}

{% schema %}
{
    "name": "Collection — Hero Filters",
    "class": "collection--section section--canonical",
    "settings": [
        {
            "type": "checkbox",
            "id": "show_collection_image",
            "label": "t:sections.collection_pages.show_collection_image.label",
            "default": true
        },
        {
            "type": "range",
            "id": "products_per_page_range",
            "label": "t:sections.collection_pages.products_per_page_range.label",
            "min": 24,
            "max": 48,
            "step": 12,
            "default": 24
        },
        {
            "type": "select",
            "id": "products_per_row",
            "label": "t:sections.collection_pages.products_per_row.label",
            "options": [
                { "label": "t:sections.collection_pages.products_per_row.option_1", "value": "3" },
                { "label": "t:sections.collection_pages.products_per_row.option_2", "value": "4" }
            ],
            "default": "4"
        },
        {
            "type": "header",
            "content": "t:sections.collection_pages.header_1.content"
        },
        {
            "type": "checkbox",
            "id": "sort_by",
