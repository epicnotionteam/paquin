{% comment %}
// Output Subcollection Feed component
{% endcomment %}

{% comment %} Output component {% endcomment %}
<div class="feed--collection variant--subcollection">
    {% assign child_collections = data_subcollections.value %}
    {% for subcollection in child_collections %}
        {% assign collection = collections[subcollection.handle] %}
        {% assign collection_url = collection.url %}
        {% assign collection_title = collection.title %}
        <div class="item">
            {% comment %} Image (falls back to a Shopify placeholder SVG when the collection has no image set) {% endcomment %}
            <a class="item__wrap--image" href="{{ collection_url }}" aria-label="{{ collection_title | escape }}">
                {% if collection.image %}
                    <img class="item__image"
                         src="{{ collection.image | image_url: width: 512 }}"
                         srcset="{{ collection.image | image_url: width: 256 }} 256w, {{ collection.image | image_url: width: 512 }} 512w, {{ collection.image | image_url: width: 768 }} 768w"
                         sizes="(max-width: 600px) 33vw, (max-width: 860px) 20vw, 14vw"
                         alt="{{ collection_title | escape }}"
                         width="{{ collection.image.width }}"
                         height="{{ collection.image.height }}"
                         loading="lazy">
                {% else %}
                    {%- capture index -%}{%- cycle '1', '2', '3', '4', '5', '6' -%}{%- endcapture -%}
                    {{ 'collection-' | append: index | placeholder_svg_tag: 'item__image placeholder--image' }}
                {% endif %}
            </a>

            {% comment %} Title {% endcomment %}
            <h3 class="item__title"><a href="{{ collection_url }}">{{ collection_title }}</a></h3>
        </div>
    {% endfor %}
</div>